      "sourceClasses": ["TwoWheelerclass"],
      "addons": {
        "nil_depreciation": {
          "oldApkLabel": "Nil Depreciation",
          "eligibility": "not allowed when age >= 5 years",
          "rules": [
            { "when": "vehicle_type == 'New' and tenure == 'LONG TERM'", "ratePercentOfBasicOdAndAccessories": 28 },
            { "when": "age_years == 0", "ratePercentOfBasicOdAndAccessories": 10 },
            { "when": "age_years == 1", "ratePercentOfBasicOdAndAccessories": 20 },
            { "when": "age_years > 1 and age_years < 5", "ratePercentOfBasicOdAndAccessories": 30 }
          ],
          "formula": "(basic_od + electrical_accessories) * rate / 100"
        },
        "consummables": {
          "oldApkLabel": "Consummables",
          "eligibility": "not allowed when age >= 5 years",
          "rules": [
            { "when": "vehicle_type == 'New' and tenure == 'LONG TERM'", "ratePercentOfIdv": 0.45 },
            { "when": "age_years == 0", "ratePercentOfIdv": 0.1 },
            { "when": "age_years == 1", "ratePercentOfIdv": 0.12 },
            { "when": "age_years == 2", "ratePercentOfIdv": 0.15 },
            { "when": "age_years == 3", "ratePercentOfIdv": 0.17 },
            { "when": "age_years == 4", "ratePercentOfIdv": 0.2 }
          ],
          "formula": "idv * rate / 100"
        },
        "road_side_assistance": {
          "oldApkLabel": "Roadside Assistance",
          "flatPremium": 25
        },
        "return_to_invoice": {
          "oldApkLabel": "Return to Invoice",
          "eligibility": "not allowed when age >= 3 years",
